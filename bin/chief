#!/usr/bin/env sh
set -eu

LEDGER_CONFIG_URL="${CHIEF_LEDGER_HTTP_URL:-${CHIEF_LEDGER_URL:-https://ledger.curawealth.ai/mcp/}}"
LEDGER_FALLBACK_URL="${CHIEF_LEDGER_FALLBACK_URL:-}"

case "$LEDGER_CONFIG_URL" in
  */mcp/)
    LEDGER_URL="${LEDGER_CONFIG_URL%/mcp/}"
    ;;
  */mcp)
    LEDGER_URL="${LEDGER_CONFIG_URL%/mcp}"
    ;;
  *)
    LEDGER_URL="$LEDGER_CONFIG_URL"
    ;;
esac

usage() {
  cat <<'EOF'
Chief CLI for ZeroClaw

Usage:
  chief ledger health
  chief ledger state
  chief ledger route '<json-intent>'
  chief ledger wallet get-or-create '<json>'
  chief ledger credit AGENT_ID AMOUNT_ATOMIC [reason]
  chief ledger transfer '{"toEmail":"agent@example.com","amount":"0.001 U"}'
  chief ledger escrow create '<json>'
  chief ledger escrow release ESCROW_ID
  chief ledger escrow refund ESCROW_ID

Environment:
  CHIEF_LEDGER_URL             default hosted ledger MCP endpoint
                                accepts either service base URL or /mcp/ URL
  CHIEF_LEDGER_HTTP_URL        optional explicit service base URL for CLI REST calls
  CHIEF_LEDGER_FALLBACK_URL    optional fallback service base URL
EOF
}

get_url() {
  primary="$1"
  fallback="$2"
  path="$3"
  if [ -n "$fallback" ]; then
    curl -fsS "$primary$path" 2>/dev/null || curl -sS "$fallback$path"
  else
    curl -fsS "$primary$path"
  fi
}

sanitize_ledger_state() {
  sed -E 's/"availableAtomic"[[:space:]]*:[[:space:]]*"[^"]*",[[:space:]]*//g; s/,[[:space:]]*"availableAtomic"[[:space:]]*:[[:space:]]*"[^"]*"//g'
}

json_string_field() {
  key="$1"
  body="$2"
  printf '%s' "$body" | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -n 1
}

url_encode_query_value() {
  printf '%s' "$1" | sed 's/%/%25/g; s/@/%40/g; s/+/%2B/g; s/&/%26/g; s/=/%3D/g; s/ /%20/g'
}

agent_profile_json() {
  profile_path="${CHIEF_AGENT_PROFILE_PATH:-}"
  if [ -z "$profile_path" ] && [ -n "${ZEROCLAW_WORKSPACE:-}" ]; then
    profile_path="$ZEROCLAW_WORKSPACE/.eigenflux/servers/eigenflux/profile.json"
  fi
  if [ -z "$profile_path" ]; then
    for candidate in \
      "$PWD/.eigenflux/servers/eigenflux/profile.json" \
      "/zeroclaw-data/workspace/.eigenflux/servers/eigenflux/profile.json" \
      "${HOME:-}/.eigenflux/servers/eigenflux/profile.json"
    do
      if [ -n "$candidate" ] && [ -f "$candidate" ]; then
        profile_path="$candidate"
        break
      fi
    done
  fi

  if [ -n "$profile_path" ] && [ -f "$profile_path" ]; then
    cat "$profile_path"
    return
  fi

  printf '{}\n'
}

ledger_state_path_for_profile() {
  profile="$(agent_profile_json)"
  profile_agent_id="$(json_string_field agent_id "$profile")"
  if [ -z "$profile_agent_id" ]; then
    profile_agent_id="$(json_string_field agentId "$profile")"
  fi
  if [ -z "$profile_agent_id" ]; then
    echo "current ZeroClaw profile is missing agent_id" >&2
    return 2
  fi
  printf '/ledger/state?agentId=%s\n' "$(url_encode_query_value "$profile_agent_id")"
}

post_json() {
  url="$1"
  fallback_url="$2"
  body="$3"
  if [ -n "$fallback_url" ]; then
    curl -fsS -X POST "$url" \
      -H 'Content-Type: application/json' \
      -H 'Accept: application/json, text/event-stream' \
      --data "$body" 2>/dev/null \
      || curl -sS -X POST "$fallback_url" \
        -H 'Content-Type: application/json' \
        -H 'Accept: application/json, text/event-stream' \
        --data "$body"
  else
    curl -fsS -X POST "$url" \
      -H 'Content-Type: application/json' \
      -H 'Accept: application/json, text/event-stream' \
      --data "$body"
  fi
}

route_payment_intent() {
  intent="$1"
  if printf '%s' "$intent" | grep -Eq '"deliveryMode"[[:space:]]*:[[:space:]]*"funding"'; then
    cat <<'EOF'
{"method":"onramp","needsClarification":false,"allowedTools":["agent_wallet_create_onramp_session"],"reason":"Funding must create a hosted onramp session; ledger balance is credited only after provider-confirmed settlement."}
EOF
    return
  fi
  if printf '%s' "$intent" | grep -Eq '"deliveryMode"[[:space:]]*:[[:space:]]*"agent_transfer"'; then
    cat <<'EOF'
{"method":"ledger_transfer","needsClarification":false,"allowedTools":["agent_wallet_transfer"],"reason":"Immediate internal Agent-to-Agent payments must perform a real Circle USDC transfer before the ledger records the transfer."}
EOF
    return
  fi
  if printf '%s' "$intent" | grep -Eq '"deliveryMode"[[:space:]]*:[[:space:]]*"withdrawal"'; then
    cat <<'EOF'
{"method":"needs_clarification","needsClarification":true,"allowedTools":[],"reason":"This install kit only exposes ledger wallet, escrow, and settlement operations. Ask the operator before handling withdrawals."}
EOF
    return
  fi
  if printf '%s' "$intent" | grep -Eq '"deliveryMode"[[:space:]]*:[[:space:]]*"immediate_api"'; then
    cat <<'EOF'
{"method":"needs_clarification","needsClarification":true,"allowedTools":[],"reason":"This install kit only exposes ledger wallet, escrow, and settlement operations. Ask the operator before immediate paid API calls."}
EOF
    return
  fi
  if printf '%s' "$intent" | grep -Eq '"deliveryMode"[[:space:]]*:[[:space:]]*"async_task"|"requiresAcceptance"[[:space:]]*:[[:space:]]*true'; then
    cat <<'EOF'
{"method":"ledger_escrow","needsClarification":false,"allowedTools":["agent_wallet_create_escrow","agent_wallet_release_escrow","agent_wallet_refund_escrow"],"reason":"Matched asynchronous task payments require ledger escrow so funds can be locked, released, or refunded."}
EOF
    return
  fi
  cat <<'EOF'
{"method":"needs_clarification","needsClarification":true,"allowedTools":[],"reason":"The payment intent is ambiguous. Clarify whether this is funding or asynchronous task escrow before proceeding."}
EOF
}

transfer_payload_from_email() {
  request="$1"
  profile_path="${CHIEF_AGENT_PROFILE_PATH:-}"
  if [ -z "$profile_path" ] && [ -n "${ZEROCLAW_WORKSPACE:-}" ]; then
    profile_path="$ZEROCLAW_WORKSPACE/.eigenflux/servers/eigenflux/profile.json"
  fi
  if [ -z "$profile_path" ]; then
    for candidate in \
      "$PWD/.eigenflux/servers/eigenflux/profile.json" \
      "/zeroclaw-data/workspace/.eigenflux/servers/eigenflux/profile.json" \
      "${HOME:-}/.eigenflux/servers/eigenflux/profile.json"
    do
      if [ -n "$candidate" ] && [ -f "$candidate" ]; then
        profile_path="$candidate"
        break
      fi
    done
  fi
  profile="{}"
  if [ -n "$profile_path" ] && [ -f "$profile_path" ]; then
    profile="$(cat "$profile_path")"
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 -c '
import json
import re
import sys
from decimal import Decimal, InvalidOperation

request = json.loads(sys.argv[1])
profile = json.loads(sys.argv[2])

if not isinstance(request, dict):
    raise SystemExit("transfer payload must be a JSON object")
if "fromAgentId" in request or "toAgentId" in request:
    raise SystemExit("fromAgentId/toAgentId are internal; use toEmail with amount or amountAtomic")

to_email = str(request.get("toEmail") or request.get("email") or "").strip().lower()
if not to_email:
    raise SystemExit("transfer requires toEmail")

def parse_amount_atomic(value):
    if value is None:
        raise SystemExit("transfer requires amount or amountAtomic")
    text = str(value).strip()
    if re.fullmatch(r"[0-9]+", text):
        amount = int(text)
    else:
        match = re.fullmatch(r"([0-9]+(?:\.[0-9]+)?)\s*(?:U|USDC)?", text, re.IGNORECASE)
        if not match:
            raise SystemExit("amount must be an integer atomic value or decimal USDC like 0.001 U")
        try:
            decimal = Decimal(match.group(1))
        except InvalidOperation:
            raise SystemExit("amount must be an integer atomic value or decimal USDC like 0.001 U")
        atomic_decimal = decimal * Decimal(1000000)
        if atomic_decimal != atomic_decimal.to_integral_value():
            raise SystemExit("amount is smaller than one atomic USDC unit")
        amount = int(atomic_decimal)
    if amount <= 0:
        raise SystemExit("amount must be positive")
    return str(amount)

amount_atomic = parse_amount_atomic(request.get("amountAtomic", request.get("amount")))
profile_email = str(profile.get("email") or "").strip().lower()
if not profile_email:
    raise SystemExit("current ZeroClaw profile is missing email")
if profile_email == to_email:
    raise SystemExit("sender and receiver must be different emails")

reason = str(request.get("reason") or f"direct transfer to {to_email}")
print(json.dumps({
    "fromEmail": profile_email,
    "toEmail": to_email,
    "amountAtomic": amount_atomic,
    "reason": reason,
}, separators=(",", ":")))
' "$request" "$profile"
    return
  fi

  if printf '%s' "$request" | grep -Eq '"fromAgentId"[[:space:]]*:|"toAgentId"[[:space:]]*:'; then
    echo "fromAgentId/toAgentId are internal; use toEmail with amount or amountAtomic" >&2
    return 2
  fi

  json_string_field() {
    key="$1"
    body="$2"
    printf '%s' "$body" | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -n 1
  }

  to_email="$(json_string_field toEmail "$request")"
  if [ -z "$to_email" ]; then
    to_email="$(json_string_field email "$request")"
  fi
  to_email="$(printf '%s' "$to_email" | tr '[:upper:]' '[:lower:]')"
  if [ -z "$to_email" ]; then
    echo "transfer requires toEmail" >&2
    return 2
  fi

  amount_text="$(json_string_field amountAtomic "$request")"
  if [ -z "$amount_text" ]; then
    amount_text="$(json_string_field amount "$request")"
  fi
  if [ -z "$amount_text" ]; then
    echo "transfer requires amount or amountAtomic" >&2
    return 2
  fi
  amount_compact="$(printf '%s' "$amount_text" | tr -d '[:space:]' | sed 's/[Uu][Ss][Dd][Cc]$//; s/[Uu]$//')"
  amount_atomic="$(awk -v value="$amount_compact" '
    BEGIN {
      if (value ~ /^[0-9]+$/) {
        amount = value + 0
      } else if (value ~ /^[0-9]+(\.[0-9]+)?$/) {
        amount = value * 1000000
      } else {
        exit 2
      }
      if (amount <= 0) {
        exit 3
      }
      rounded = int(amount)
      if (amount != rounded) {
        exit 4
      }
      printf "%.0f", amount
    }
  ')" || {
    echo "amount must be an integer atomic value or decimal USDC like 0.001 U" >&2
    return 2
  }

  profile_email="$(json_string_field email "$profile" | tr '[:upper:]' '[:lower:]')"
  if [ -z "$profile_email" ]; then
    echo "current ZeroClaw profile is missing email" >&2
    return 2
  fi
  if [ "$profile_email" = "$to_email" ]; then
    echo "sender and receiver must be different emails" >&2
    return 2
  fi

  reason="$(json_string_field reason "$request")"
  if [ -z "$reason" ]; then
    reason="direct transfer to $to_email"
  fi
  json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
  }
  printf '{"fromEmail":"%s","toEmail":"%s","amountAtomic":"%s","reason":"%s"}\n' \
    "$(json_escape "$profile_email")" \
    "$(json_escape "$to_email")" \
    "$(json_escape "$amount_atomic")" \
    "$(json_escape "$reason")"
}

case "${1:-}" in
  ledger)
    case "${2:-}" in
      health)
        get_url "$LEDGER_URL" "$LEDGER_FALLBACK_URL" "/health"
        ;;
      state)
        state_path="$(ledger_state_path_for_profile)" || exit 2
        get_url "$LEDGER_URL" "$LEDGER_FALLBACK_URL" "$state_path" | sanitize_ledger_state
        ;;
      route)
        [ $# -ge 3 ] || { echo "usage: chief ledger route '<json-intent>'" >&2; exit 2; }
        route_payment_intent "$3"
        ;;
      wallet)
        case "${3:-}" in
          get-or-create)
            [ $# -ge 4 ] || { echo "usage: chief ledger wallet get-or-create '<json>'" >&2; exit 2; }
            post_json "$LEDGER_URL/ledger/wallets/get-or-create" "${LEDGER_FALLBACK_URL:+$LEDGER_FALLBACK_URL/ledger/wallets/get-or-create}" "$4"
            ;;
          *)
            usage
            exit 2
            ;;
        esac
        ;;
      credit)
        [ $# -ge 4 ] || { echo "usage: chief ledger credit AGENT_ID AMOUNT_ATOMIC [reason]" >&2; exit 2; }
        reason="${5:-manual credit}"
        post_json "$LEDGER_URL/ledger/accounts/$3/credit" "${LEDGER_FALLBACK_URL:+$LEDGER_FALLBACK_URL/ledger/accounts/$3/credit}" "{\"amountAtomic\":\"$4\",\"reason\":\"$reason\"}"
        ;;
      transfer)
        [ $# -ge 3 ] || { echo "usage: chief ledger transfer '{\"toEmail\":\"agent@example.com\",\"amount\":\"0.001 U\"}'" >&2; exit 2; }
        route_result="$(route_payment_intent '{"deliveryMode":"agent_transfer","requiresAcceptance":false,"asset":"USDC"}')"
        if ! printf '%s' "$route_result" | grep -Eq '"needsClarification"[[:space:]]*:[[:space:]]*false'; then
          printf '%s\n' "$route_result" >&2
          exit 2
        fi
        if ! printf '%s' "$route_result" | grep -q '"agent_wallet_transfer"'; then
          printf '%s\n' "$route_result" >&2
          exit 2
        fi
        transfer_body="$(transfer_payload_from_email "$3")" || exit 2
        post_json "$LEDGER_URL/ledger/transfers" "${LEDGER_FALLBACK_URL:+$LEDGER_FALLBACK_URL/ledger/transfers}" "$transfer_body"
        ;;
      escrow)
        case "${3:-}" in
          create)
            [ $# -ge 4 ] || { echo "usage: chief ledger escrow create '<json>'" >&2; exit 2; }
            post_json "$LEDGER_URL/ledger/escrows" "${LEDGER_FALLBACK_URL:+$LEDGER_FALLBACK_URL/ledger/escrows}" "$4"
            ;;
          release)
            [ $# -ge 4 ] || { echo "usage: chief ledger escrow release ESCROW_ID" >&2; exit 2; }
            post_json "$LEDGER_URL/ledger/escrows/$4/release" "${LEDGER_FALLBACK_URL:+$LEDGER_FALLBACK_URL/ledger/escrows/$4/release}" '{}'
            ;;
          refund)
            [ $# -ge 4 ] || { echo "usage: chief ledger escrow refund ESCROW_ID" >&2; exit 2; }
            post_json "$LEDGER_URL/ledger/escrows/$4/refund" "${LEDGER_FALLBACK_URL:+$LEDGER_FALLBACK_URL/ledger/escrows/$4/refund}" '{}'
            ;;
          *)
            usage
            exit 2
            ;;
        esac
        ;;
      *)
        usage
        exit 2
        ;;
    esac
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
